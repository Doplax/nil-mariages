---
import { futureProjects, countryImage } from '../data/countries';
import { getDict, type Lang } from '../i18n';
import Flag from './Flag.astro';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.future;
---

<section class="future section" id="proyectos">
  <div class="container">
    <SectionHeader light class="future-head" eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    <div class="future-grid">
      {
        futureProjects.map((iso, i) => (
          <Reveal class="future-card" delay={i * 80}>
            <img src={countryImage(iso)} alt={d.future[iso].name} loading="lazy" width="700" height="500" />
            <div class="future-overlay" />
            <div class="future-content">
              <span class="future-flag">
                <Flag iso={iso} h={15} label={d.future[iso].name} />
                {t.soon}
              </span>
              <h3>{d.future[iso].name}</h3>
              <p>{d.future[iso].desc}</p>
            </div>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>

<style>
  .future {
    background: var(--navy);
    color: var(--cream);
  }
  .future-head {
    margin-bottom: 44px;
  }
  .future-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 22px;
  }
  .future-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 360px;
    display: flex;
    align-items: flex-end;
    box-shadow: var(--shadow-lg);
  }
  .future-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .future-card:hover img {
    transform: scale(1.07);
  }
  .future-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(9, 22, 34, 0.94) 6%, rgba(9, 22, 34, 0.4) 52%, rgba(9, 22, 34, 0.1));
  }
  .future-content {
    position: relative;
    z-index: 2;
    padding: 24px;
  }
  .future-flag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--teal-bright);
    margin-bottom: 10px;
  }
  .future-content h3 {
    font-size: 1.5rem;
  }
  .future-content p {
    margin-top: 8px;
    color: rgba(245, 250, 249, 0.82);
    font-size: 0.95rem;
  }
</style>
