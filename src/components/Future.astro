---
import { futureProjects } from '../data/countries';
import { getDict, type Lang } from '../i18n';
import FutureCard from './FutureCard.astro';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.future;
---

<section class="future section" id="proyectos">
  <div class="container">
    <SectionHeader light eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    <div class="future-grid">
      {
        futureProjects.map((iso, i) => (
          <Reveal delay={i * 70}>
            <FutureCard
              iso={iso}
              name={d.future[iso].name}
              description={d.future[iso].desc}
              badge={t.soon}
            />
          </Reveal>
        ))
      }
    </div>
  </div>
</section>

<style>
  .future {
    background: var(--navy);
    color: var(--cream);
  }
  .future-grid {
    margin-top: 44px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 22px;
  }
</style>
