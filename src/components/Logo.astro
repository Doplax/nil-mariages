---
interface Props {
  /** Color del texto: 'navy' sobre fondo claro, 'cream' sobre fondo oscuro */
  variant?: 'navy' | 'cream';
  /** Muestra la línea de tagline bajo el nombre */
  tagline?: boolean;
}
const { variant = 'navy', tagline = true } = Astro.props;
const nameColor = variant === 'navy' ? 'var(--navy)' : 'var(--cream)';
const tagColor = variant === 'navy' ? 'var(--teal-deep)' : 'var(--teal-bright)';
---

<span class="logo" aria-label="Nil Mariages, travel maker">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="34" height="34" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="32" height="32" rx="9" fill="var(--teal)"></rect>
      <path
        d="M8 16.5l16-8-5.5 16-3-6.2L8 16.5z"
        fill="var(--navy)"
        stroke="var(--navy)"
        stroke-width="1.4"
        stroke-linejoin="round"
      ></path>
      <path d="M15.5 18.3L24 8.5" stroke="var(--teal)" stroke-width="1.3" stroke-linecap="round"></path>
    </svg>
  </span>
  <span class="logo-text">
    <span class="logo-name" style={`color:${nameColor}`}>Nil <span class="logo-accent">Mariages</span></span>
    {tagline && <span class="logo-tag" style={`color:${tagColor}`}>Travel maker</span>}
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }
  .logo-mark {
    display: inline-flex;
    flex-shrink: 0;
    box-shadow: 0 6px 16px -8px rgba(95, 201, 188, 0.9);
    border-radius: 9px;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .logo-name {
    font-size: 1.22rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .logo-accent {
    color: var(--teal);
  }
  .logo-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-top: 2px;
  }
</style>
