---
import { countryImage, flagUrl } from '../data/countries';

interface Props {
  name: string;
  iso: string;
  description: string;
  compact?: boolean;
}

const { name, iso, description, compact = false } = Astro.props;
const img = countryImage(name);
---

<article class={`country-card${compact ? ' compact' : ''}`}>
  <div class="country-media">
    <img src={img} alt={`${name} — paisaje representativo`} loading="lazy" width="600" height="450" />
    <span class="country-gradient" aria-hidden="true"></span>
    <span class="country-name">
      <img class="country-flag" src={flagUrl(iso, 40)} alt={`Bandera de ${name}`} width="22" height="15" loading="lazy" />
      {name}
    </span>
  </div>
  <div class="country-body">
    <p>{description}</p>
  </div>
</article>

<style>
  .country-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }
  .country-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(95, 201, 188, 0.5);
  }
  .country-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--navy-soft), var(--navy));
    overflow: hidden;
  }
  .country-media img:first-child {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .country-card:hover .country-media img:first-child {
    transform: scale(1.07);
  }
  .country-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(9, 22, 34, 0.85) 0%, rgba(9, 22, 34, 0.15) 42%, transparent 70%);
  }
  .country-name {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 12px;
    display: flex;
    align-items: center;
    gap: 9px;
    color: #fff;
    font-weight: 700;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }
  .country-flag {
    width: 22px;
    height: 15px;
    border-radius: 3px;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }
  .country-body {
    padding: 14px 16px 18px;
  }
  .country-body p {
    color: var(--muted);
    font-size: 0.92rem;
  }

  /* Variante compacta para Europa */
  .country-card.compact .country-media {
    aspect-ratio: 16 / 10;
  }
  .country-card.compact .country-name {
    font-size: 0.98rem;
  }
  .country-card.compact .country-body {
    padding: 11px 13px 14px;
  }
  .country-card.compact .country-body p {
    font-size: 0.84rem;
  }
</style>
