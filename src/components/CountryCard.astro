---
import { countryImage } from '../data/countries';

interface Props {
  name: string;
  flag: string;
  description: string;
  imageQuery: string;
  compact?: boolean;
}

const { name, flag, description, imageQuery, compact = false } = Astro.props;
const img = countryImage(imageQuery);
---

<article class={`country-card${compact ? ' compact' : ''}`}>
  <div class="country-media">
    <img src={img} alt={`Imagen de ${name}`} loading="lazy" width="600" height="450" />
    <span class="country-flag">{flag}</span>
  </div>
  <div class="country-body">
    <h3>{name}</h3>
    <p>{description}</p>
  </div>
</article>

<style>
  .country-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .country-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .country-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--navy-soft), var(--navy));
    overflow: hidden;
  }
  .country-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .country-card:hover .country-media img {
    transform: scale(1.06);
  }
  .country-flag {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 1.2rem;
    background: rgba(9, 22, 34, 0.6);
    backdrop-filter: blur(4px);
    border-radius: 8px;
    padding: 3px 8px;
    line-height: 1.2;
  }
  .country-body {
    padding: 16px 18px 20px;
  }
  .country-body h3 {
    font-size: 1.15rem;
  }
  .country-body p {
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  /* Variante compacta para Europa */
  .country-card.compact .country-media {
    aspect-ratio: 16 / 9;
  }
  .country-card.compact .country-body {
    padding: 12px 14px 16px;
  }
  .country-card.compact .country-body h3 {
    font-size: 1rem;
  }
  .country-card.compact .country-body p {
    font-size: 0.85rem;
    margin-top: 5px;
  }
</style>
