---
import type { Lang } from '../i18n';
import Hero from './Hero.astro';
import About from './About.astro';
import Resume from './Resume.astro';
import Experience from './Experience.astro';
import TripsSection from './TripsSection.astro';
import Future from './Future.astro';
import CTA from './CTA.astro';
import Testimonials from './Testimonials.astro';
import ContactForm from './ContactForm.astro';
import PlanningSection from './PlanningSection.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Hero lang={lang} />
<About lang={lang} />
<Resume lang={lang} />
<Experience lang={lang} />
<TripsSection lang={lang} />
<PlanningSection lang={lang} />
<Future lang={lang} />
<Testimonials lang={lang} />
<CTA lang={lang} />
<ContactForm lang={lang} />
