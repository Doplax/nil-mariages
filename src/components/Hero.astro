---
import { totalCountries } from '../data/countries';
import { getDict, type Lang } from '../i18n';
import Stat from './ui/Stat.astro';
import Button from './ui/Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.hero;
---

<section class="hero" id="inicio">
  <div class="hero-bg" aria-hidden="true">
    <svg class="hero-routes" data-parallax="0.22" viewBox="0 0 1440 760" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <!-- Rutas de vuelo animadas -->
      <path class="route route-1" d="M-40,540 C 240,430 520,380 760,330 S 1240,190 1520,120" />
      <path class="route route-2" d="M-40,200 C 260,150 520,300 800,360 S 1280,430 1520,360" />
      <path class="route route-3" d="M120,740 C 360,580 620,560 880,470 S 1320,370 1540,430" />

      <!-- Puntos de destino -->
      <circle class="dot dot-1" cx="760" cy="330" r="4" />
      <circle class="dot dot-2" cx="800" cy="360" r="4" />
      <circle class="dot dot-3" cx="880" cy="470" r="4" />
      <circle class="dot dot-4" cx="1520" cy="120" r="4" />

      <!-- Aviones en movimiento a lo largo de las rutas -->
      <g class="plane plane-1">
        <path d="M9,0 L-8,-6 L-3,0 L-8,6 Z" />
      </g>
      <g class="plane plane-2">
        <path d="M9,0 L-8,-6 L-3,0 L-8,6 Z" />
      </g>
    </svg>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <span class="hero-tag">✈️ {t.tag}</span>
      <h1 class="hero-title">
        {t.titleTop}<br />
        <span class="hero-accent">{t.titleAccent}</span>
      </h1>
      <p class="hero-lead" set:html={t.lead.replace('Nil Mariages', '<strong>Nil Mariages</strong>')} />
      <div class="hero-actions">
        <Button href="#experiencia" variant="primary">{t.ctaPrimary}</Button>
        <Button href="#contacto" variant="ghost">{t.ctaGhost}</Button>
      </div>
      <div class="hero-stats">
        <Stat value={`+${totalCountries}`} label={t.statCountries} />
        <Stat value="4" label={t.statContinents} />
        <Stat value="100%" label={t.statTailored} />
      </div>
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    color: var(--cream);
    background: linear-gradient(160deg, var(--navy), var(--navy-deep));
    overflow: hidden;
    clip-path: inset(0);
    padding-top: 150px;
    padding-bottom: 120px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    /* Resplandor muy sutil y centrado en la parte superior (sin "manchas"). */
    background: radial-gradient(120% 75% at 50% -20%, rgba(95, 201, 188, 0.1), transparent 60%);
  }
  .hero-routes {
    position: absolute;
    top: -15%;
    left: 0;
    width: 100%;
    height: 130%;
    will-change: transform;
  }

  .route {
    fill: none;
    stroke: var(--teal);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 5 11;
    opacity: 0.32;
    animation: route-flow linear infinite;
  }
  .route-1 {
    animation-duration: 5s;
  }
  .route-2 {
    opacity: 0.22;
    animation-duration: 7s;
  }
  .route-3 {
    opacity: 0.16;
    animation-duration: 9s;
  }
  @keyframes route-flow {
    to {
      stroke-dashoffset: -160;
    }
  }

  .dot {
    fill: var(--teal-bright);
    opacity: 0.5;
    animation: dot-pulse 3s ease-in-out infinite;
  }
  .dot-2 {
    animation-delay: 0.6s;
  }
  .dot-3 {
    animation-delay: 1.2s;
  }
  .dot-4 {
    animation-delay: 1.8s;
  }
  @keyframes dot-pulse {
    0%,
    100% {
      opacity: 0.25;
      r: 3;
    }
    50% {
      opacity: 0.8;
      r: 5;
    }
  }

  .plane path {
    fill: var(--teal-bright);
  }
  .plane {
    offset-rotate: auto;
    animation: plane-fly linear infinite;
    filter: drop-shadow(0 0 6px rgba(122, 217, 205, 0.6));
  }
  .plane-1 {
    offset-path: path('M-40,540 C 240,430 520,380 760,330 S 1240,190 1520,120');
    animation-duration: 11s;
  }
  .plane-2 {
    offset-path: path('M-40,200 C 260,150 520,300 800,360 S 1280,430 1520,360');
    animation-duration: 15s;
    animation-delay: 3s;
  }
  @keyframes plane-fly {
    from {
      offset-distance: 0%;
    }
    to {
      offset-distance: 100%;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
  }
  .hero-content {
    max-width: 720px;
  }
  .hero-tag {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(95, 201, 188, 0.14);
    border: 1px solid rgba(95, 201, 188, 0.3);
    color: var(--teal-bright);
    font-weight: 600;
    font-size: 0.9rem;
    backdrop-filter: blur(4px);
  }
  .hero-title {
    margin-top: 24px;
    font-size: clamp(2.4rem, 6vw, 4.3rem);
    font-weight: 800;
  }
  .hero-accent {
    background: linear-gradient(100deg, var(--teal-bright), var(--teal));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lead {
    margin-top: 22px;
    max-width: 56ch;
    font-size: 1.18rem;
    color: rgba(245, 250, 249, 0.82);
  }
  .hero-lead strong {
    color: var(--cream);
  }
  .hero-actions {
    margin-top: 34px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero-stats {
    margin-top: 52px;
    display: flex;
    gap: 44px;
    flex-wrap: wrap;
  }
  .hero-fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent, var(--cream));
    z-index: 1;
  }

  /* Entrada animada del contenido del hero al cargar */
  .hero-content > * {
    animation: hero-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero-content > *:nth-child(1) {
    animation-delay: 0.05s;
  }
  .hero-content > *:nth-child(2) {
    animation-delay: 0.15s;
  }
  .hero-content > *:nth-child(3) {
    animation-delay: 0.25s;
  }
  .hero-content > *:nth-child(4) {
    animation-delay: 0.35s;
  }
  .hero-content > *:nth-child(5) {
    animation-delay: 0.45s;
  }
  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .hero-stats {
      gap: 28px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .route,
    .dot,
    .plane {
      animation: none;
    }
    .plane {
      display: none;
    }
  }
</style>
