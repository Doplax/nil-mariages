---
import { getDict, type Lang } from '../i18n';
import { profile } from '../data/cv';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.about;
const icons = ['🎯', '🤝', '🏔️', '🌐'];
---

<section class="about section" id="sobre-mi">
  <div class="container about-inner">
    <div class="about-photo reveal">
      <div class="about-photo-frame">
        <img
          src="/images/nil-mariages.webp"
          width="800"
          height="800"
          alt={`${profile.name}, ${t.role}`}
          loading="lazy"
        />
      </div>
      <div class="about-badge">
        <span>{profile.name}</span>
        <small>{t.role}</small>
      </div>
    </div>

    <div class="about-text reveal">
      <span class="eyebrow">● {t.eyebrow}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="about-body">{t.p1}</p>
      <p class="about-body">{t.p2}</p>

      <div class="about-grid">
        {
          t.cards.map((h, i) => (
            <div class="about-card">
              <span class="about-card-icon">{icons[i]}</span>
              <div>
                <h3>{h.title}</h3>
                <p>{h.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  .about-photo {
    position: relative;
  }
  .about-photo-frame {
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 1;
  }
  .about-photo-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.2);
    transform-origin: 68% 78%;
  }
  .about-photo::before {
    content: '';
    position: absolute;
    inset: -18px -18px auto auto;
    width: 70%;
    height: 70%;
    background: linear-gradient(140deg, var(--teal), transparent);
    border-radius: var(--radius-lg);
    z-index: -1;
    opacity: 0.4;
  }
  .about-badge {
    position: absolute;
    right: 20px;
    top: 20px;
    background: rgba(9, 22, 34, 0.78);
    backdrop-filter: blur(8px);
    color: var(--cream);
    padding: 12px 20px;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .about-badge span {
    font-weight: 700;
  }
  .about-badge small {
    color: var(--teal-bright);
    font-size: 0.8rem;
  }

  .about-body {
    margin-top: 18px;
    color: var(--muted);
    font-size: 1.05rem;
  }
  .about-grid {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .about-card {
    display: flex;
    gap: 14px;
    padding: 18px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease;
  }
  .about-card:hover {
    transform: translateY(-3px);
  }
  .about-card-icon {
    font-size: 1.5rem;
    line-height: 1;
  }
  .about-card h3 {
    font-size: 1rem;
    margin-bottom: 4px;
  }
  .about-card p {
    font-size: 0.9rem;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .about-inner {
      grid-template-columns: 1fr;
    }
    .about-photo {
      max-width: 420px;
    }
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
