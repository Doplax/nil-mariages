---
import { trips } from '../data/trips';
import { countryImage } from '../data/countries';
import { getDict, type Lang } from '../i18n';
import Flag from './Flag.astro';
import SectionHeader from './ui/SectionHeader.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.trips;

// El mapa real (Google My Maps) no se carga hasta que el visitante pulsa la
// fachada: la página inicial es más ligera y no se cargan cookies de Google
// hasta que se piden. El texto vive en i18n, indexado por slug.
const items = trips.map((trip) => {
  const text = d.trips[trip.slug];
  return {
    ...trip,
    text,
    image: countryImage(trip.iso),
    viewerSrc: trip.embedSrc.replace('/embed', '/viewer'),
    locationLabel: `${text.location}${trip.year ? ` · ${trip.year}` : ''}`,
  };
});

const hasTrips = items.length > 0;
const multi = items.length > 1;
const first = items[0];
---

<section class="trips section" id="rutas">
  <div class="container">
    <SectionHeader class="trips-head" eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    {
      hasTrips && first && (
        <div class="trips-layout reveal">
          {multi && (
            <div class="trip-tabs" role="tablist" aria-label={t.title}>
              {items.map((it, i) => (
                <button
                  class={`trip-tab${i === 0 ? ' active' : ''}`}
                  data-index={i}
                  data-embed={it.embedSrc}
                  data-viewer={it.viewerSrc}
                  data-image={it.image}
                  data-title={it.text.title}
                  data-location={it.locationLabel}
                  data-desc={it.text.description}
                  data-stops={JSON.stringify(it.text.stops ?? [])}
                  type="button"
                  role="tab"
                  aria-selected={i === 0}
                >
                  <Flag iso={it.iso} h={14} label={it.text.location} />
                  <span class="trip-tab-title">{it.text.title}</span>
                </button>
              ))}
            </div>
          )}

          <div
            class="trip-stage"
            id="trip-stage"
            data-embed={first.embedSrc}
            data-title={first.text.title}
            data-load-label={t.loadMap}
          >
            <button
              class="trip-facade"
              type="button"
              style={`background-image:url('${first.image}')`}
              aria-label={`${t.loadMap}: ${first.text.title}`}
            >
              <span class="trip-facade-cta">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m3 6 6-3 6 3 6-3v15l-6 3-6-3-6 3z" />
                  <path d="M9 3v15" />
                  <path d="M15 6v15" />
                </svg>
                {t.loadMap}
              </span>
              <span class="trip-facade-note">{t.loadNote}</span>
            </button>
          </div>

          <figcaption class="trip-caption">
            <div class="trip-caption-head">
              <h3 class="trip-caption-title" id="trip-info-title">
                {first.text.title}
              </h3>
              <p class="trip-caption-loc" id="trip-info-location">
                {first.locationLabel}
              </p>
              <a
                class="trip-open"
                id="trip-open"
                href={first.viewerSrc}
                target="_blank"
                rel="noopener"
              >
                {t.openMap}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 17 17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </a>
            </div>
            <div class="trip-caption-body">
              <p class="trip-caption-desc" id="trip-info-desc">
                {first.text.description}
              </p>
              {first.text.stops && first.text.stops.length > 0 && (
                <ul class="trip-stops" id="trip-info-stops" aria-label={t.stopsLabel}>
                  {first.text.stops.map((s) => (
                    <li class="trip-stop">{s}</li>
                  ))}
                </ul>
              )}
            </div>
          </figcaption>
        </div>
      )
    }
  </div>
</section>

<script>
  // El mapa de cada ruta es el embed de Google My Maps, pero NO se carga hasta
  // que el visitante pulsa la fachada (mejor rendimiento y sin cookies de Google
  // de entrada). Si hay más de una ruta, las pestañas cambian la información y
  // reinician el escenario a la fachada de la nueva ruta.
  function loadStageMap(stage: HTMLElement) {
    if (stage.dataset.loaded === '1') return;
    const embed = stage.dataset.embed;
    if (!embed) return;
    stage.dataset.loaded = '1';

    const iframe = document.createElement('iframe');
    iframe.className = 'trip-embed';
    iframe.src = embed;
    iframe.title = stage.dataset.title ?? '';
    iframe.loading = 'lazy';
    iframe.referrerPolicy = 'no-referrer-when-downgrade';
    iframe.allowFullscreen = true;
    stage.replaceChildren(iframe);
  }

  function initTrips() {
    const stage = document.getElementById('trip-stage');
    if (!stage) return;

    // El listener vive en el escenario (no en la fachada), así sobrevive a que
    // se reconstruya la fachada al cambiar de pestaña.
    if (stage.dataset.bound !== '1') {
      stage.dataset.bound = '1';
      // Plantilla de la fachada (con su texto e icono ya traducidos) para poder
      // recrearla al cambiar de ruta.
      const facadeHTML = stage.innerHTML;
      stage.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.trip-facade')) loadStageMap(stage);
      });
      (stage as any)._facadeHTML = facadeHTML;
    }

    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.trip-tab'));
    if (tabs.length < 2) return;

    const titleEl = document.getElementById('trip-info-title');
    const locEl = document.getElementById('trip-info-location');
    const descEl = document.getElementById('trip-info-desc');
    const stopsEl = document.getElementById('trip-info-stops');
    const openEl = document.getElementById('trip-open') as HTMLAnchorElement | null;

    tabs.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        tabs.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        // Reinicia el escenario a la fachada de la nueva ruta.
        stage.dataset.embed = btn.dataset.embed ?? '';
        stage.dataset.title = btn.dataset.title ?? '';
        stage.dataset.loaded = '';
        stage.innerHTML = (stage as any)._facadeHTML ?? '';
        const facade = stage.querySelector<HTMLElement>('.trip-facade');
        if (facade) {
          facade.style.backgroundImage = `url('${btn.dataset.image}')`;
          facade.setAttribute('aria-label', `${stage.dataset.loadLabel ?? ''}: ${btn.dataset.title ?? ''}`);
        }

        if (titleEl) titleEl.textContent = btn.dataset.title ?? '';
        if (locEl) locEl.textContent = btn.dataset.location ?? '';
        if (descEl) descEl.textContent = btn.dataset.desc ?? '';
        if (openEl && btn.dataset.viewer) openEl.href = btn.dataset.viewer;
        if (stopsEl) {
          const stops = JSON.parse(btn.dataset.stops ?? '[]') as string[];
          stopsEl.replaceChildren(
            ...stops.map((s) => {
              const li = document.createElement('li');
              li.className = 'trip-stop';
              li.textContent = s;
              return li;
            }),
          );
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initTrips);
  if (document.readyState !== 'loading') initTrips();
</script>

<style>
  .trips {
    background: var(--cream);
  }
  .trips-head {
    max-width: 760px;
    margin-bottom: 40px;
  }
  .trips-layout {
    display: grid;
    gap: 16px;
  }

  /* Pestañas (solo cuando hay más de una ruta) */
  .trip-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .trip-tab {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 16px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .trip-tab:hover {
    border-color: var(--teal);
  }
  .trip-tab.active {
    background: var(--navy);
    color: var(--cream);
    border-color: var(--navy);
  }

  /* El mapa, protagonista: ancho completo, proporción 16:9 */
  .trip-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--line);
    background: #e8eef0;
  }
  .trip-embed {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Fachada: foto del destino + botón para cargar el mapa real */
  .trip-facade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px;
    border: 0;
    cursor: pointer;
    background-color: var(--navy);
    background-size: cover;
    background-position: center;
    color: var(--cream);
    font-family: inherit;
    text-align: center;
  }
  .trip-facade::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(11, 28, 38, 0.3), rgba(11, 28, 38, 0.7));
    transition: background 0.25s ease;
  }
  .trip-facade:hover::before,
  .trip-facade:focus-visible::before {
    background: linear-gradient(180deg, rgba(11, 28, 38, 0.22), rgba(11, 28, 38, 0.58));
  }
  .trip-facade-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 11px;
    padding: 14px 26px;
    border-radius: 999px;
    background: var(--teal);
    color: var(--navy-deep);
    font-weight: 700;
    font-size: 1.05rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }
  .trip-facade:hover .trip-facade-cta,
  .trip-facade:focus-visible .trip-facade-cta {
    transform: translateY(-2px);
    background: var(--teal-bright);
  }
  .trip-facade-cta svg {
    width: 22px;
    height: 22px;
  }
  .trip-facade-note {
    position: relative;
    font-size: 0.82rem;
    color: rgba(245, 250, 249, 0.85);
  }

  /* Pie: a la izquierda título + enlace; a la derecha descripción + paradas */
  .trip-caption {
    display: grid;
    grid-template-columns: minmax(220px, 300px) 1fr;
    gap: 32px;
    align-items: start;
    margin-top: 26px;
    padding: 0 4px;
  }
  .trip-caption-title {
    font-size: 1.75rem;
    line-height: 1.15;
    color: var(--ink);
  }
  .trip-caption-loc {
    margin-top: 6px;
    color: var(--teal-deep);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .trip-open {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 14px;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--teal-deep);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .trip-open:hover {
    color: var(--navy);
  }
  .trip-open svg {
    width: 15px;
    height: 15px;
  }
  .trip-caption-desc {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .trip-stops {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .trip-stop {
    display: inline-flex;
    align-items: center;
    padding: 6px 13px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--line);
    color: var(--ink);
    font-size: 0.85rem;
    font-weight: 600;
  }

  @media (max-width: 820px) {
    .trip-caption {
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 20px;
    }
    .trip-caption-title {
      font-size: 1.45rem;
    }
  }
  @media (max-width: 640px) {
    .trip-stage {
      aspect-ratio: 4 / 5;
    }
  }
</style>
