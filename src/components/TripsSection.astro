---
import 'leaflet/dist/leaflet.css';
import { trips } from '../data/trips';
import { getDict, type Lang } from '../i18n';
import Flag from './Flag.astro';
import SectionHeader from './ui/SectionHeader.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.trips;
const hasTrips = trips.length > 0;
---

<section class="trips section" id="rutas">
  <div class="container">
    <SectionHeader class="trips-head" eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    {
      hasTrips && (
        <div class="trips-layout reveal">
          <div class="trip-tabs" role="tablist" aria-label={t.title}>
            {trips.map((trip, i) => (
              <button
                class={`trip-tab${i === 0 ? ' active' : ''}`}
                data-index={i}
                data-title={d.trips[trip.slug].title}
                data-location={`${d.trips[trip.slug].location}${trip.year ? ` · ${trip.year}` : ''}`}
                data-desc={d.trips[trip.slug].description}
                type="button"
                role="tab"
                aria-selected={i === 0}
              >
                <Flag iso={trip.iso} h={14} label={d.trips[trip.slug].location} />
                <span class="trip-tab-title">{d.trips[trip.slug].title}</span>
                {trip.sample && <span class="trip-tab-badge">{t.sampleBadge}</span>}
              </button>
            ))}
          </div>

          <div class="trip-viewbar" id="trip-viewbar" hidden>
            <div class="trip-viewtoggle" role="group" aria-label={t.title}>
              <button class="vt-btn active" data-view="map" type="button" aria-pressed="true">
                {t.mapTab}
              </button>
              <button class="vt-btn" data-view="embed" type="button" aria-pressed="false">
                {t.embedTab}
              </button>
            </div>
          </div>

          <div class="trip-stage">
            <div class="trip-canvas">
              <div id="trip-map" class="trip-map" role="application" aria-label={t.title}></div>
              <iframe
                id="trip-embed"
                class="trip-embed"
                title={t.title}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                hidden></iframe>
            </div>
            <div class="trip-info" id="trip-info">
              <h3 id="trip-info-title" />
              <p id="trip-info-location" class="trip-info-location" />
              <p id="trip-info-desc" />
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>

<script>
  import { trips } from '../data/trips';

  // Se re-inicializa en cada `astro:page-load` para que el mapa cargue tras
  // una View Transition (cambio de idioma), no solo al recargar la página.
  let tripsObserver: IntersectionObserver | null = null;

  function initTrips() {
    const mapEl = document.getElementById('trip-map');
    if (!mapEl || !trips.length) return;
    // Idempotente: si initTrips se llama dos veces sobre el mismo nodo (por el
    // fallback de readyState además de astro:page-load) la segunda salida temprana.
    if (mapEl.dataset.tripsReady === '1') return;
    mapEl.dataset.tripsReady = '1';

  // Leaflet (152 KB) se carga de forma diferida: solo cuando la sección del
  // mapa se acerca al viewport, para no penalizar la carga inicial.
  async function initMap() {
    let L: typeof import('leaflet');
    try {
      L = (await import('leaflet')).default;
    } catch (err) {
      // En dev, Vite puede invalidar su caché de dependencias y devolver un 504
      // "Outdated Optimize Dep" en el import dinámico. En producción, un deploy
      // puede renombrar el chunk mientras hay una pestaña abierta. En ambos casos
      // un único recargado recupera el módulo correcto (la guarda evita un bucle).
      console.warn('[trips] no se pudo cargar leaflet, se recarga una vez', err);
      if (!sessionStorage.getItem('trips-map-reloaded')) {
        sessionStorage.setItem('trips-map-reloaded', '1');
        location.reload();
      }
      return;
    }
    sessionStorage.removeItem('trips-map-reloaded');
    const map = L.map(mapEl as HTMLElement, { scrollWheelZoom: false, zoomControl: true }).setView([41.9, 75.5], 7);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      maxZoom: 20,
      subdomains: 'abcd',
    }).addTo(map);

    let layer: any = null;

    const titleEl = document.getElementById('trip-info-title');
    const locEl = document.getElementById('trip-info-location');
    const descEl = document.getElementById('trip-info-desc');
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.trip-tab'));

    // Conmutador "Vista interactiva" (Leaflet) ↔ "Mapa completo" (embed de Google
    // My Maps). El embed solo está disponible en las rutas que tienen `embedSrc`.
    const embedEl = document.getElementById('trip-embed') as HTMLIFrameElement | null;
    const viewbar = document.getElementById('trip-viewbar');
    const viewBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.vt-btn'));
    let currentIndex = 0;
    let currentView: 'map' | 'embed' = 'map';

    function applyView(view: 'map' | 'embed') {
      const trip = trips[currentIndex];
      const hasEmbed = !!trip?.embedSrc;
      currentView = view === 'embed' && hasEmbed ? 'embed' : 'map';

      if (currentView === 'embed' && embedEl) {
        if (embedEl.getAttribute('src') !== trip!.embedSrc) {
          embedEl.setAttribute('src', trip!.embedSrc as string);
        }
        embedEl.hidden = false;
        mapEl!.hidden = true;
      } else {
        if (embedEl) embedEl.hidden = true;
        mapEl!.hidden = false;
        // Recalcula tamaño y reencuadra: si el mapa estuvo oculto (en el embed),
        // su tamaño era 0 y el último fitBounds pudo quedar descuadrado.
        setTimeout(() => {
          map.invalidateSize();
          const b = layer?.getBounds();
          if (b && b.isValid()) map.fitBounds(b, { padding: [40, 40] });
        }, 60);
      }

      viewBtns.forEach((b) => {
        const on = b.dataset.view === currentView;
        b.classList.toggle('active', on);
        b.setAttribute('aria-pressed', String(on));
      });
    }

    function syncViewbar(index: number) {
      currentIndex = index;
      const hasEmbed = !!trips[index]?.embedSrc;
      if (viewbar) viewbar.hidden = !hasEmbed;
      // Una ruta sin embed siempre se ve en el mapa interactivo; si estábamos en
      // el embed y cambiamos a otra ruta con mapa propio, refrescamos el iframe.
      if (!hasEmbed) applyView('map');
      else if (currentView === 'embed') applyView('embed');
    }

    viewBtns.forEach((b) =>
      b.addEventListener('click', () => applyView((b.dataset.view as 'map' | 'embed') || 'map')),
    );

    function renderTrip(index: number) {
      const trip = trips[index];
      if (!trip) return;

      if (layer) layer.remove();

      layer = L.geoJSON(trip.data as any, {
        style: () => ({ color: '#3da093', weight: 4, opacity: 0.9 }),
        pointToLayer: (_feature, latlng) =>
          L.circleMarker(latlng, {
            radius: 7,
            fillColor: '#5fc9bc',
            color: '#0e2336',
            weight: 2,
            opacity: 1,
            fillOpacity: 1,
          }),
        onEachFeature: (feature, lyr) => {
          const props = feature.properties || {};
          if (props.name && feature.geometry?.type === 'Point') {
            lyr.bindPopup(
              `<strong>${props.name}</strong>${props.description ? `<br>${props.description}` : ''}`,
            );
          }
        },
      }).addTo(map);

      const bounds = layer.getBounds();
      if (bounds.isValid()) map.fitBounds(bounds, { padding: [40, 40] });

      const btn = tabs[index];
      if (titleEl) titleEl.textContent = btn?.dataset.title ?? '';
      if (locEl) locEl.textContent = btn?.dataset.location ?? '';
      if (descEl) descEl.textContent = btn?.dataset.desc ?? '';

      syncViewbar(index);
    }

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        tabs.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        renderTrip(Number(btn.dataset.index));
      });
    });

    renderTrip(0);
    // Recalcula el tamaño tras el primer render (evita el mapa gris)
    setTimeout(() => map.invalidateSize(), 200);
  }

    tripsObserver?.disconnect();
    tripsObserver = new IntersectionObserver(
      (entries, obs) => {
        if (entries.some((e) => e.isIntersecting)) {
          obs.disconnect();
          initMap();
        }
      },
      { rootMargin: '300px' },
    );
    tripsObserver.observe(mapEl);
  }

  document.addEventListener('astro:page-load', initTrips);
  // Fallback: si este módulo se evalúa DESPUÉS de que `astro:page-load` ya haya
  // disparado (orden de carga / caché / HMR), el listener no se ejecutaría nunca
  // y la sección quedaría en blanco. Inicializamos también de inmediato cuando el
  // DOM ya está listo; la guarda `tripsReady` evita la doble inicialización.
  if (document.readyState !== 'loading') initTrips();
</script>

<style>
  .trips {
    background: var(--cream);
  }
  .trips-head {
    max-width: 760px;
    margin-bottom: 40px;
  }
  .trips-layout {
    display: grid;
    gap: 18px;
  }
  .trip-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .trip-tab {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 16px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .trip-tab:hover {
    border-color: var(--teal);
  }
  .trip-tab.active {
    background: var(--navy);
    color: var(--cream);
    border-color: var(--navy);
  }
  .trip-tab-badge {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: rgba(95, 201, 188, 0.2);
    color: var(--teal-deep);
    padding: 2px 7px;
    border-radius: 999px;
  }
  .trip-tab.active .trip-tab-badge {
    color: var(--teal-bright);
    background: rgba(95, 201, 188, 0.18);
  }

  .trip-viewbar {
    display: flex;
    justify-content: flex-end;
  }
  .trip-viewbar[hidden] {
    display: none;
  }
  .trip-viewtoggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .vt-btn {
    border: 0;
    background: transparent;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.86rem;
    color: var(--ink);
    padding: 7px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .vt-btn:hover {
    color: var(--teal-deep);
  }
  .vt-btn.active {
    background: var(--navy);
    color: var(--cream);
  }

  .trip-stage {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--line);
    background: #fff;
  }
  .trip-canvas {
    position: relative;
    min-width: 0;
  }
  .trip-map {
    height: 480px;
    width: 100%;
    background: #e8eef0;
    z-index: 1;
  }
  .trip-map[hidden] {
    display: none;
  }
  .trip-embed {
    display: block;
    height: 480px;
    width: 100%;
    border: 0;
    background: #e8eef0;
  }
  .trip-embed[hidden] {
    display: none;
  }
  .trip-info {
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(160deg, var(--navy), var(--navy-deep));
    color: var(--cream);
  }
  .trip-info h3 {
    font-size: 1.5rem;
  }
  .trip-info-location {
    margin-top: 6px;
    color: var(--teal-bright);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .trip-info p:last-child {
    margin-top: 14px;
    color: rgba(245, 250, 249, 0.82);
    font-size: 0.96rem;
  }

  /* La atribución y los controles de Leaflet con la tipografía del sitio */
  :global(.leaflet-container) {
    font-family: var(--font);
  }

  @media (max-width: 820px) {
    .trip-stage {
      grid-template-columns: 1fr;
    }
    .trip-map,
    .trip-embed {
      height: 380px;
    }
  }
</style>
