---
import { trips } from '../data/trips';
import { getDict, type Lang } from '../i18n';
import Flag from './Flag.astro';
import SectionHeader from './ui/SectionHeader.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.trips;

const hasTrips = trips.length > 0;
const multi = trips.length > 1;
const first = trips[0];
const firstText = first ? d.trips[first.slug] : null;
const firstLocation =
  first && firstText ? `${firstText.location}${first.year ? ` · ${first.year}` : ''}` : '';
---

<section class="trips section" id="rutas">
  <div class="container">
    <SectionHeader class="trips-head" eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    {
      hasTrips && first && firstText && (
        <div class="trips-layout reveal">
          {multi && (
            <div class="trip-tabs" role="tablist" aria-label={t.title}>
              {trips.map((trip, i) => (
                <button
                  class={`trip-tab${i === 0 ? ' active' : ''}`}
                  data-index={i}
                  data-embed={trip.embedSrc}
                  data-title={d.trips[trip.slug].title}
                  data-location={`${d.trips[trip.slug].location}${trip.year ? ` · ${trip.year}` : ''}`}
                  data-desc={d.trips[trip.slug].description}
                  type="button"
                  role="tab"
                  aria-selected={i === 0}
                >
                  <Flag iso={trip.iso} h={14} label={d.trips[trip.slug].location} />
                  <span class="trip-tab-title">{d.trips[trip.slug].title}</span>
                  {trip.sample && <span class="trip-tab-badge">{t.sampleBadge}</span>}
                </button>
              ))}
            </div>
          )}

          <div class="trip-stage">
            <iframe
              id="trip-embed"
              class="trip-embed"
              src={first.embedSrc}
              title={firstText.title}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          </div>

          <figcaption class="trip-caption">
            <div class="trip-caption-head">
              <h3 class="trip-caption-title" id="trip-info-title">
                {firstText.title}
              </h3>
              <p class="trip-caption-loc" id="trip-info-location">
                {firstLocation}
              </p>
            </div>
            <p class="trip-caption-desc" id="trip-info-desc">
              {firstText.description}
            </p>
          </figcaption>
        </div>
      )
    }
  </div>
</section>

<script>
  import { trips } from '../data/trips';

  // El mapa es el embed de Google My Maps (iframe). Si hay más de una ruta, las
  // pestañas cambian el `src` del iframe y el pie de descripción. Con una sola
  // ruta no hay pestañas y todo se sirve renderizado, sin JS.
  function initTrips() {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.trip-tab'));
    if (tabs.length < 2) return;

    const iframe = document.getElementById('trip-embed') as HTMLIFrameElement | null;
    const titleEl = document.getElementById('trip-info-title');
    const locEl = document.getElementById('trip-info-location');
    const descEl = document.getElementById('trip-info-desc');
    if (!iframe || iframe.dataset.tripsReady === '1') return;
    iframe.dataset.tripsReady = '1';

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        tabs.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        const src = btn.dataset.embed;
        if (src && iframe.getAttribute('src') !== src) iframe.setAttribute('src', src);
        if (titleEl) titleEl.textContent = btn.dataset.title ?? '';
        if (locEl) locEl.textContent = btn.dataset.location ?? '';
        if (descEl) descEl.textContent = btn.dataset.desc ?? '';
      });
    });
  }

  document.addEventListener('astro:page-load', initTrips);
  if (document.readyState !== 'loading') initTrips();
</script>

<style>
  .trips {
    background: var(--cream);
  }
  .trips-head {
    max-width: 760px;
    margin-bottom: 40px;
  }
  .trips-layout {
    display: grid;
    gap: 16px;
  }

  /* Pestañas (solo cuando hay más de una ruta) */
  .trip-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .trip-tab {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 16px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .trip-tab:hover {
    border-color: var(--teal);
  }
  .trip-tab.active {
    background: var(--navy);
    color: var(--cream);
    border-color: var(--navy);
  }
  .trip-tab-badge {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: rgba(95, 201, 188, 0.2);
    color: var(--teal-deep);
    padding: 2px 7px;
    border-radius: 999px;
  }
  .trip-tab.active .trip-tab-badge {
    color: var(--teal-bright);
    background: rgba(95, 201, 188, 0.18);
  }

  /* El mapa, protagonista: ancho completo y bien alto */
  .trip-stage {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--line);
    background: #e8eef0;
  }
  .trip-embed {
    display: block;
    width: 100%;
    height: 620px;
    border: 0;
  }

  /* Descripción debajo del mapa */
  .trip-caption {
    display: grid;
    grid-template-columns: minmax(220px, 300px) 1fr;
    gap: 32px;
    align-items: start;
    margin-top: 26px;
    padding: 0 4px;
  }
  .trip-caption-title {
    font-size: 1.75rem;
    line-height: 1.15;
    color: var(--ink);
  }
  .trip-caption-loc {
    margin-top: 6px;
    color: var(--teal-deep);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .trip-caption-desc {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 70ch;
  }

  @media (max-width: 980px) {
    .trip-embed {
      height: 520px;
    }
  }
  @media (max-width: 820px) {
    .trip-embed {
      height: 440px;
    }
    .trip-caption {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 20px;
    }
    .trip-caption-title {
      font-size: 1.45rem;
    }
  }
</style>
