---
import { getDict, type Lang } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';
import Flag from './Flag.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.testimonials;
---

<section class="testimonials section">
  <div class="container">
    <SectionHeader eyebrow={t.eyebrow} title={t.title} lead={t.lead} />
    <div class="testi-grid">
      {t.items.map((item, i) => (
        <Reveal delay={i * 80}>
          <blockquote class="testi-card card">
            <div class="testi-quote" aria-hidden="true">"</div>
            <p class="testi-text">{item.text}</p>
            <footer class="testi-footer">
              <div class="testi-avatar" aria-hidden="true">{item.name.charAt(0)}</div>
              <div class="testi-meta">
                <cite class="testi-name">{item.name}</cite>
                <span class="testi-role">
                  <Flag iso={item.country} h={13} label="" />
                  {item.role}
                </span>
              </div>
            </footer>
          </blockquote>
        </Reveal>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--navy);
  }
  .testimonials :global(.section-title),
  .testimonials :global(.eyebrow) {
    color: var(--cream);
  }
  .testimonials :global(.eyebrow) {
    color: var(--teal-bright);
  }
  .testimonials :global(.section-lead) {
    color: rgba(245, 250, 249, 0.68);
  }
  .testi-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  .testi-card {
    position: relative;
    padding: 32px;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.22s ease, border-color 0.22s ease;
    margin: 0;
  }
  .testi-card:hover {
    transform: translateY(-4px);
    border-color: rgba(95, 201, 188, 0.4);
  }
  .testi-quote {
    font-size: 4.5rem;
    line-height: 0.6;
    color: var(--teal);
    opacity: 0.6;
    font-family: Georgia, serif;
    pointer-events: none;
  }
  .testi-text {
    color: rgba(245, 250, 249, 0.88);
    font-size: 1rem;
    line-height: 1.7;
    font-style: italic;
    flex: 1;
  }
  .testi-footer {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal-deep), var(--teal));
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .testi-name {
    display: block;
    font-style: normal;
    font-weight: 700;
    color: var(--cream);
    font-size: 0.96rem;
  }
  .testi-role {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: rgba(245, 250, 249, 0.55);
    margin-top: 2px;
  }

  @media (max-width: 640px) {
    .testi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
