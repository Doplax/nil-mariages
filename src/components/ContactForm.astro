---
import { profile } from '../data/cv';
import { getDict, type Lang } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.contact;
---

<section class="contact section" id="contacto-form">
  <div class="container contact-inner">
    <Reveal class="contact-info">
      <SectionHeader eyebrow={t.eyebrow} title={t.title} lead={t.lead} />
      <ul class="contact-links">
        <li>
          <a href={`mailto:${profile.email}`} class="contact-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            {profile.email}
          </a>
        </li>
        <li>
          <a href={profile.phoneHref} class="contact-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.15 6.15l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {profile.phone}
          </a>
        </li>
        <li>
          <a href={profile.whatsapp} target="_blank" rel="noopener" class="contact-link contact-link-wa">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
            WhatsApp
          </a>
        </li>
      </ul>
    </Reveal>

    <Reveal class="contact-form-wrap" delay={80}>
      <form
          class="contact-form"
          id="contact-form"
          novalidate
        >

          <div class="form-row">
            <label class="form-label" for="contact-name">Nombre</label>
            <input id="contact-name" name="name" type="text" class="form-input" placeholder={t.namePlaceholder} required autocomplete="name" />
          </div>
          <div class="form-row">
            <label class="form-label" for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" class="form-input" placeholder={t.emailPlaceholder} required autocomplete="email" />
          </div>
          <div class="form-row">
            <label class="form-label" for="contact-msg">Mensaje</label>
            <textarea id="contact-msg" name="message" class="form-input form-textarea" placeholder={t.msgPlaceholder} rows="5" required></textarea>
          </div>

          <p class="form-privacy">{t.privacy}</p>

          <button type="submit" class="btn btn-primary form-submit">{t.submit}</button>
          <p class="form-success" id="form-success" hidden>{t.success}</p>
      </form>
    </Reveal>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const submit = form?.querySelector<HTMLButtonElement>('[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submit) return;
    submit.disabled = true;
    submit.textContent = '…';

    try {
      const fd = new FormData(form);
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name'),
          email: fd.get('email'),
          message: fd.get('message'),
        }),
      });
      const data = await res.json();
      if (data.success) {
        form.reset();
        if (success) success.hidden = false;
        submit.hidden = true;
      } else {
        submit.disabled = false;
        submit.textContent = submit.dataset.label ?? 'Enviar';
      }
    } catch {
      submit.disabled = false;
      submit.textContent = submit.dataset.label ?? 'Enviar';
    }
  });
</script>

<style>
  .contact {
    background: var(--cream);
  }
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 72px;
    align-items: start;
  }
  .contact-links {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    color: var(--ink);
    transition: color 0.18s ease;
    font-size: 0.98rem;
  }
  .contact-link:hover { color: var(--teal-deep); }
  .contact-link svg { color: var(--teal-deep); flex-shrink: 0; }
  .contact-link-wa svg { color: #25d366; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-label {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .form-input {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    font-family: var(--font);
    font-size: 1rem;
    color: var(--ink);
    background: #fff;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
    outline: none;
  }
  .form-input:focus {
    border-color: var(--teal-deep);
    box-shadow: 0 0 0 3px rgba(95, 201, 188, 0.18);
  }
  .form-textarea { resize: vertical; min-height: 130px; }
  .form-privacy {
    font-size: 0.82rem;
    color: var(--muted);
    margin: -4px 0 0;
  }
  .form-submit { align-self: flex-start; }
  .form-success {
    font-weight: 700;
    color: var(--teal-deep);
    margin: 0;
  }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  .contact-fallback {
    background: rgba(95,201,188,0.08);
    border: 1px dashed var(--teal-deep);
    border-radius: var(--radius);
    padding: 24px;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .contact-fallback code {
    background: rgba(14,35,54,0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  .contact-fallback a { color: var(--teal-deep); text-decoration: underline; }

  @media (max-width: 860px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
