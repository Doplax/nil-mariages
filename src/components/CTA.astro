---
import { totalCountries } from '../data/countries';
import { profile } from '../data/cv';
import { getDict, interpolate, type Lang } from '../i18n';
import Button from './ui/Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.cta;
---

<section class="cta">
  <div class="container cta-inner reveal">
    <span class="cta-plane" data-parallax="0.14" aria-hidden="true">✈</span>
    <div class="cta-text">
      <h2>{t.title}</h2>
      <p>{interpolate(t.text, { count: totalCountries })}</p>
    </div>
    <div class="cta-actions">
      <Button href={`mailto:${profile.email}`} variant="primary">{t.email}</Button>
      <Button href={profile.whatsapp} variant="ghost" external>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"></path>
        </svg>
        {t.whatsapp}
      </Button>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: 28px clamp(48px, 7vw, 84px);
    background: var(--navy);
  }
  .cta-inner {
    background: linear-gradient(120deg, var(--teal-deep), var(--teal));
    border-radius: var(--radius-lg);
    padding: clamp(32px, 5vw, 56px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
  }
  .cta-plane {
    position: absolute;
    right: 4%;
    top: -34px;
    font-size: 12rem;
    line-height: 1;
    color: rgba(9, 22, 34, 0.08);
    pointer-events: none;
    will-change: transform;
    z-index: 0;
  }
  .cta-text {
    position: relative;
    z-index: 1;
  }
  .cta-text h2 {
    font-size: clamp(1.6rem, 3.2vw, 2.3rem);
    color: var(--navy);
  }
  .cta-text p {
    margin-top: 12px;
    max-width: 52ch;
    color: rgba(9, 22, 34, 0.78);
    font-size: 1.05rem;
    font-weight: 500;
  }
  .cta-actions {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .cta-actions :global(.btn-primary) {
    background: var(--navy);
    color: var(--cream);
  }
  .cta-actions :global(.btn-primary:hover) {
    background: var(--navy-deep);
  }
  .cta-actions :global(.btn-ghost) {
    color: var(--navy);
    border-color: rgba(9, 22, 34, 0.45);
  }
  .cta-actions :global(.btn-ghost:hover) {
    color: var(--navy-deep);
    border-color: var(--navy);
  }
</style>
