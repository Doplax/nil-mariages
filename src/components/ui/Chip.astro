---
// Etiqueta tipo "pill" reutilizable.
interface Props {
  variant?: 'soft' | 'solid' | 'outline';
  class?: string;
}
const { variant = 'soft', class: cls = '' } = Astro.props;
---

<span class:list={['chip', `chip-${variant}`, cls]}>
  <slot />
</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
    padding: 5px 14px;
    line-height: 1.3;
  }
  .chip-soft {
    background: rgba(95, 201, 188, 0.16);
    color: var(--teal-deep);
  }
  .chip-outline {
    border: 1px solid rgba(95, 201, 188, 0.3);
    color: var(--teal-deep);
  }
  .chip-solid {
    background: var(--teal);
    color: var(--navy);
  }
</style>
