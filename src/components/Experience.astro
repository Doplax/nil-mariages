---
import { regions } from '../data/countries';
import { getDict, type Lang } from '../i18n';
import RegionBlock from './RegionBlock.astro';
import SectionHeader from './ui/SectionHeader.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.experience;
---

<section class="experience section" id="experiencia">
  <div class="container">
    <SectionHeader class="exp-head" eyebrow={t.eyebrow} title={t.title} lead={t.lead} />

    {regions.map((region) => <RegionBlock region={region} lang={lang} />)}
  </div>
</section>

<style>
  .exp-head {
    margin-bottom: 48px;
    max-width: 780px;
  }
</style>
