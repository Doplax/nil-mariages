---
import { regions, flagUrl } from '../data/countries';
import CountryCard from './CountryCard.astro';

const featured = regions.filter((r) => r.featured);
const europe = regions.find((r) => !r.featured);
---

<section class="experience section" id="experiencia">
  <div class="container">
    <div class="exp-head reveal">
      <span class="eyebrow">● Experiencia viajera</span>
      <h2 class="section-title">Más de 40 países, cuatro continentes</h2>
      <p class="section-lead">
        Lo internacional es lo que más me apasiona. Cada destino me ha dejado mapas, contactos y un
        conocimiento práctico que vuelco en cada viaje que diseño. Estos son algunos de los lugares que
        he recorrido.
      </p>
    </div>

    {
      featured.map((region) => (
        <div class="region reveal">
          <div class="region-head">
            <h3>
              <span class="region-icon">{region.icon}</span>
              {region.title}
            </h3>
            {region.subtitle && <span class="region-subtitle">{region.subtitle}</span>}
            <span class="region-flags" aria-hidden="true">
              {region.countries.slice(0, 8).map((c) => (
                <img src={flagUrl(c.iso, 40)} alt="" width="22" height="15" loading="lazy" />
              ))}
            </span>
            <span class="region-count">{region.countries.length} países</span>
          </div>
          <div class="region-grid">
            {region.countries.map((c) => (
              <CountryCard name={c.name} iso={c.iso} description={c.description} />
            ))}
          </div>
        </div>
      ))
    }

    {
      europe && (
        <div class="region region-europe reveal">
          <div class="region-head">
            <h3>
              <span class="region-icon">{europe.icon}</span>
              {europe.title}
            </h3>
            {europe.subtitle && <span class="region-subtitle">{europe.subtitle}</span>}
            <span class="region-count">{europe.countries.length} países</span>
          </div>
          <div class="region-grid compact-grid">
            {europe.countries.map((c) => (
              <CountryCard name={c.name} iso={c.iso} description={c.description} compact />
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .exp-head {
    margin-bottom: 48px;
    max-width: 780px;
  }
  .region {
    margin-top: 60px;
  }
  .region:first-of-type {
    margin-top: 0;
  }
  .region-head {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 22px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }
  .region-head h3 {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
  .region-icon {
    font-size: 1.55rem;
  }
  .region-subtitle {
    padding: 5px 14px;
    background: rgba(95, 201, 188, 0.16);
    color: var(--teal-deep);
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
  }
  .region-flags {
    display: none;
    align-items: center;
    gap: 5px;
    margin-left: 6px;
  }
  .region-flags img {
    width: 22px;
    height: 15px;
    border-radius: 3px;
    object-fit: cover;
    box-shadow: 0 1px 3px rgba(14, 35, 54, 0.2);
  }
  .region-count {
    margin-left: auto;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .region-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 22px;
  }
  .compact-grid {
    grid-template-columns: repeat(auto-fill, minmax(205px, 1fr));
    gap: 16px;
  }

  @media (min-width: 960px) {
    .region-flags {
      display: flex;
    }
  }
  @media (max-width: 520px) {
    .region-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .compact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
