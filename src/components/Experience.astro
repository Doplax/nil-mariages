---
import { regions } from '../data/countries';
import CountryCard from './CountryCard.astro';
import Flag from './Flag.astro';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';
import Chip from './ui/Chip.astro';

const featured = regions.filter((r) => r.featured);
const europe = regions.find((r) => !r.featured);
---

<section class="experience section" id="experiencia">
  <div class="container">
    <SectionHeader
      class="exp-head"
      eyebrow="Experiencia viajera"
      title="Más de 40 países, cuatro continentes"
      lead="Lo internacional es lo que más me apasiona. Cada destino me ha dejado mapas, contactos y un conocimiento práctico que vuelco en cada viaje que diseño. Estos son algunos de los lugares que he recorrido."
    />

    {
      featured.map((region) => (
        <div class="region">
          <Reveal class="region-head">
            <h3>
              <span class="region-icon">{region.icon}</span>
              {region.title}
            </h3>
            {region.subtitle && <Chip variant="soft">{region.subtitle}</Chip>}
            <span class="region-flags" aria-hidden="true">
              {region.countries.slice(0, 8).map((c) => (
                <Flag iso={c.iso} h={15} label={c.name} />
              ))}
            </span>
            <span class="region-count">{region.countries.length} países</span>
          </Reveal>
          <div class="region-grid">
            {region.countries.map((c, i) => (
              <Reveal delay={(i % 4) * 60}>
                <CountryCard name={c.name} iso={c.iso} description={c.description} />
              </Reveal>
            ))}
          </div>
        </div>
      ))
    }

    {
      europe && (
        <div class="region region-europe">
          <Reveal class="region-head">
            <h3>
              <span class="region-icon">{europe.icon}</span>
              {europe.title}
            </h3>
            {europe.subtitle && <Chip variant="soft">{europe.subtitle}</Chip>}
            <span class="region-count">{europe.countries.length} países</span>
          </Reveal>
          <div class="region-grid compact-grid">
            {europe.countries.map((c, i) => (
              <Reveal delay={(i % 5) * 45}>
                <CountryCard name={c.name} iso={c.iso} description={c.description} compact />
              </Reveal>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .exp-head {
    margin-bottom: 48px;
    max-width: 780px;
  }
  .region {
    margin-top: 60px;
  }
  .region:first-of-type {
    margin-top: 0;
  }
  .region-head {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 22px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }
  .region-head h3 {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
  .region-icon {
    font-size: 1.55rem;
  }
  .region-flags {
    display: none;
    align-items: center;
    gap: 6px;
    margin-left: 6px;
  }
  .region-count {
    margin-left: auto;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .region-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 22px;
  }
  .compact-grid {
    grid-template-columns: repeat(auto-fill, minmax(205px, 1fr));
    gap: 16px;
  }

  @media (min-width: 960px) {
    .region-flags {
      display: flex;
    }
  }
  @media (max-width: 520px) {
    .region-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .compact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
