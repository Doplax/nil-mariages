---
import { countryImage, futureGroupFlags } from '../data/countries';
import Flag from './Flag.astro';

interface Props {
  iso: string;
  name: string;
  description: string;
  badge: string;
}
const { iso, name, description, badge } = Astro.props;
const img = countryImage(iso);
const groupFlags = futureGroupFlags[iso];
---

<article class="future-card card card-hover">
  <div class="future-media">
    <img class="future-photo" src={img} alt={name} loading="lazy" width="600" height="450" />
    <span class="future-gradient" aria-hidden="true"></span>
    <span class="future-name">
      {groupFlags
        ? groupFlags.map((f) => <Flag iso={f} h={14} label={f} />)
        : <Flag iso={iso} h={14} label={name} />
      }
      {name}
    </span>
  </div>
  <div class="future-body">
    <span class="future-badge">{badge}</span>
    <p>{description}</p>
  </div>
</article>

<style>
  .future-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .future-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--navy-soft), var(--navy));
    overflow: hidden;
  }
  .future-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .future-card:hover .future-photo {
    transform: scale(1.07);
  }
  .future-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(9, 22, 34, 0.82) 0%, rgba(9, 22, 34, 0.12) 40%, transparent 65%);
  }
  .future-name {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 12px;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
    color: #fff;
    font-weight: 700;
    font-size: 1.08rem;
    text-shadow: 0 1px 8px rgba(0,0,0,0.35);
  }
  .future-body {
    padding: 14px 16px 18px;
    background: #fff;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .future-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-deep);
  }
  .future-badge::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
  }
  .future-body p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }
</style>
