---
// Página dedicada (pantalla completa) para ver una planificación con PDF.js.
// Se abre en pestaña nueva desde la sección de itinerarios con ?src=...&title=...
// Renderiza a <canvas> en scroll continuo (carga perezosa), sin botón de
// descarga ni impresión, y con fricción anti-copia. La protección de fondo es
// la marca de agua incrustada en cada página del PDF.
import '@fontsource-variable/inter';
import '../styles/global.css';
import Logo from './Logo.astro';
import { getDict, localeUrl, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang).ui.planning;
const home = localeUrl(lang);
const titleByLang: Record<Lang, string> = {
  es: 'Planificación · Nil Mariages',
  en: 'Itinerary · Nil Mariages',
  ca: 'Planificació · Nil Mariages',
};
const backLabel: Record<Lang, string> = { es: 'Volver', en: 'Back', ca: 'Tornar' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{titleByLang[lang]}</title>
  </head>
  <body class="viewer-body">
    <header class="vp-bar">
      <a href={home} class="vp-back" aria-label={backLabel[lang]}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        <span class="vp-logo"><Logo variant="cream" /></span>
      </a>
      <h1 class="vp-title" id="vp-title"></h1>
      <span class="vp-page"><span id="vp-cur">1</span> / <span id="vp-total">…</span></span>
    </header>

    <main class="vp-stage" id="vp-stage">
      <div class="vp-loading" id="vp-loading">{t.viewerLoading}</div>
      <div class="vp-pages" id="vp-pages"></div>
    </main>

    <footer class="vp-foot">{t.viewerHint}</footer>

    <script>
      // Solo se permiten PDFs servidos desde /planificaciones/
      const ALLOWED_PREFIX = '/planificaciones/';
      const PDFJS_URL = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.7.76/build/pdf.min.mjs';
      const WORKER_URL = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.7.76/build/pdf.worker.min.mjs';

      const params = new URLSearchParams(location.search);
      const src = params.get('src') || '';
      const title = params.get('title') || '';

      const titleEl = document.getElementById('vp-title')!;
      const curEl = document.getElementById('vp-cur')!;
      const totalEl = document.getElementById('vp-total')!;
      const loading = document.getElementById('vp-loading')!;
      const pagesEl = document.getElementById('vp-pages')!;

      titleEl.textContent = title;
      if (title) document.title = title + ' · Nil Mariages';

      // Fricción anti-copia
      document.addEventListener('contextmenu', (e) => e.preventDefault());
      document.addEventListener('dragstart', (e) => e.preventDefault());
      document.addEventListener('selectstart', (e) => e.preventDefault());
      document.addEventListener('keydown', (e) => {
        const k = e.key.toLowerCase();
        if ((e.ctrlKey || e.metaKey) && (k === 's' || k === 'p')) e.preventDefault();
      });

      async function main() {
        if (!src.startsWith(ALLOWED_PREFIX)) {
          loading.textContent = '⚠︎';
          return;
        }
        const pdfjs: any = await import(/* @vite-ignore */ PDFJS_URL);
        pdfjs.GlobalWorkerOptions.workerSrc = WORKER_URL;

        const doc = await pdfjs.getDocument({ url: src }).promise;
        const total = doc.numPages;
        totalEl.textContent = String(total);
        loading.style.display = 'none';

        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const containerW = () => Math.min(900, pagesEl.clientWidth);

        // Aspecto de referencia (página 1) para dimensionar los marcadores.
        const first = await doc.getPage(1);
        const ref = first.getViewport({ scale: 1 });
        const aspect = ref.height / ref.width;

        const slots: HTMLElement[] = [];
        for (let n = 1; n <= total; n++) {
          const slot = document.createElement('div');
          slot.className = 'vp-sheet';
          slot.dataset.page = String(n);
          slot.style.aspectRatio = `${ref.width} / ${ref.height}`;
          pagesEl.appendChild(slot);
          slots.push(slot);
        }

        const rendered = new Set<number>();
        async function renderInto(slot: HTMLElement) {
          const n = Number(slot.dataset.page);
          if (rendered.has(n)) return;
          rendered.add(n);
          const page = await doc.getPage(n);
          const w = containerW();
          const scale = (w / ref.width) * dpr;
          const viewport = page.getViewport({ scale });
          const canvas = document.createElement('canvas');
          canvas.width = Math.floor(viewport.width);
          canvas.height = Math.floor(viewport.height);
          canvas.style.width = '100%';
          canvas.style.height = 'auto';
          slot.appendChild(canvas);
          slot.style.aspectRatio = '';
          const ctx = canvas.getContext('2d')!;
          await page.render({ canvasContext: ctx, viewport }).promise;
        }

        // Renderizado perezoso: pinta las páginas al acercarse al viewport.
        const renderObs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                renderInto(e.target as HTMLElement);
                renderObs.unobserve(e.target);
              }
            }
          },
          { root: null, rootMargin: '800px 0px' },
        );
        slots.forEach((s) => renderObs.observe(s));

        // Indicador de página actual según la más centrada.
        const seenObs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) curEl.textContent = (e.target as HTMLElement).dataset.page!;
            }
          },
          { root: null, rootMargin: '-45% 0px -45% 0px' },
        );
        slots.forEach((s) => seenObs.observe(s));

        // Re-render al cambiar el ancho (recalcula resolución del canvas).
        let rt: number | undefined;
        window.addEventListener('resize', () => {
          window.clearTimeout(rt);
          rt = window.setTimeout(() => {
            rendered.clear();
            slots.forEach((s) => {
              s.innerHTML = '';
              s.style.aspectRatio = `${ref.width} / ${ref.height}`;
              renderObs.observe(s);
            });
          }, 200);
        });
      }

      main().catch(() => {
        loading.textContent = '⚠︎';
      });
    </script>

    <style>
      .viewer-body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #16242f;
      }
      .vp-bar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 10px 18px;
        background: var(--navy-deep, #0b1b29);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .vp-back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--cream);
        flex-shrink: 0;
      }
      .vp-back:hover { opacity: 0.85; }
      .vp-logo { display: inline-flex; }
      .vp-logo :global(svg) { height: 22px; width: auto; }
      .vp-title {
        flex: 1;
        min-width: 0;
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: var(--cream);
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .vp-page {
        flex-shrink: 0;
        color: rgba(245, 250, 249, 0.85);
        font-size: 0.9rem;
        font-weight: 600;
        min-width: 64px;
        text-align: right;
      }
      .vp-stage {
        position: relative;
        flex: 1;
        overflow-y: auto;
        padding: 24px 16px 48px;
      }
      .vp-pages {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .vp-sheet {
        width: 100%;
        background: #20323f;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      }
      .vp-sheet canvas {
        display: block;
        user-select: none;
        -webkit-user-drag: none;
      }
      .vp-loading {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        color: rgba(245, 250, 249, 0.8);
        font-size: 1rem;
      }
      .vp-foot {
        padding: 10px 16px;
        text-align: center;
        font-size: 0.8rem;
        color: rgba(245, 250, 249, 0.55);
        background: var(--navy-deep, #0b1b29);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      @media (max-width: 560px) {
        .vp-title { display: none; }
      }
    </style>
  </body>
</html>
