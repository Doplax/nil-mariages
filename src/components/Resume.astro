---
import { profile } from '../data/cv';
import { getDict, type Lang } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import Reveal from './ui/Reveal.astro';
import Button from './ui/Button.astro';
import Chip from './ui/Chip.astro';
import SsiLogo from './SsiLogo.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const d = getDict(lang);
const t = d.ui.resume;
const { experience, education, skills, languages, awards, interests, licenses } = d.cv;
---

<section class="resume section" id="trayectoria">
  <div class="container">
    <div class="resume-head">
      <SectionHeader eyebrow={t.eyebrow} title={t.title} lead={t.lead} />
      <Reveal delay={120}>
        <Button href={profile.cvFile} download class="resume-download">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          {t.download}
        </Button>
      </Reveal>
    </div>

    <div class="resume-grid reveal">
      <!-- Columna principal: experiencia -->
      <div class="resume-main">
        <h3 class="resume-block-title">{t.expTitle}</h3>
        <div class="timeline">
          {
            experience.map((job) => (
              <article class="timeline-item">
                <div class="timeline-dot" aria-hidden="true" />
                <div class="timeline-content">
                  <div class="timeline-top">
                    <h4>{job.role}</h4>
                    <span class="timeline-period">{job.period}</span>
                  </div>
                  <p class="timeline-company">
                    <strong>{job.company}</strong> · {job.type}
                  </p>
                  <p class="timeline-summary">{job.summary}</p>
                  <ul class="timeline-bullets">
                    {job.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <!-- Columna lateral -->
      <aside class="resume-side">
        <div class="side-card">
          <h3 class="resume-block-title">{t.eduTitle}</h3>
          {
            education.map((ed) => (
              <div class="edu-item">
                <h4>{ed.title}</h4>
                <p>{ed.place}</p>
                <span class="edu-period">{ed.period}</span>
              </div>
            ))
          }
        </div>

        <div class="side-card">
          <h3 class="resume-block-title">{t.langTitle}</h3>
          {
            languages.map((language) => (
              <div class="lang-item">
                <div class="lang-top">
                  <span>{language.name}</span>
                  <span class="lang-level">{language.level}</span>
                </div>
                <div class="lang-bar" aria-hidden="true">
                  <span style={`width:${(language.value / 5) * 100}%`} />
                </div>
              </div>
            ))
          }
        </div>

        <div class="side-card">
          <h3 class="resume-block-title">{t.skillsTitle}</h3>
          <div class="chips">
            {skills.map((s) => <Chip variant="outline">{s}</Chip>)}
          </div>
        </div>

        <div class="side-card side-card-accent">
          <h3 class="resume-block-title">{t.awardsTitle}</h3>
          {awards.map((a) => (
            <p class="award">🏆 {a}</p>
          ))}
          <h3 class="resume-block-title" style="margin-top:18px">{t.licensesTitle}</h3>
          <ul class="dots-list">
            {licenses.map((l) => {
              const i = l.indexOf('SSI');
              return i === -1 ? (
                <li>{l}</li>
              ) : (
                <li class="license-ssi">{l.slice(0, i)}<SsiLogo h={20} /></li>
              );
            })}
          </ul>
          <h3 class="resume-block-title" style="margin-top:18px">{t.interestsTitle}</h3>
          <ul class="dots-list">
            {interests.map((i) => <li>{i}</li>)}
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .resume {
    background: linear-gradient(180deg, #fff, var(--cream));
  }
  .resume-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }
  .resume-head :global(.resume-download) {
    flex-shrink: 0;
  }

  .resume-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 36px;
    align-items: start;
  }
  .resume-block-title {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 20px;
  }

  /* Timeline */
  .timeline {
    position: relative;
  }
  .timeline-item {
    position: relative;
    padding-left: 30px;
    padding-bottom: 30px;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 6px;
    bottom: -6px;
    width: 2px;
    background: linear-gradient(var(--teal), rgba(95, 201, 188, 0.15));
  }
  .timeline-item:last-child {
    padding-bottom: 0;
  }
  .timeline-item:last-child::before {
    display: none;
  }
  .timeline-dot {
    position: absolute;
    left: 0;
    top: 5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 0 4px rgba(95, 201, 188, 0.18);
  }
  .timeline-content {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px 22px;
  }
  .timeline-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .timeline-top h4 {
    font-size: 1.2rem;
  }
  .timeline-period {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--teal-deep);
    background: rgba(95, 201, 188, 0.14);
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .timeline-company {
    margin-top: 6px;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .timeline-company strong {
    color: var(--ink);
  }
  .timeline-summary {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .timeline-bullets {
    margin: 14px 0 0;
    padding-left: 18px;
    display: grid;
    gap: 7px;
  }
  .timeline-bullets li {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .timeline-bullets li::marker {
    color: var(--teal);
  }

  /* Sidebar cards */
  .resume-side {
    display: grid;
    gap: 20px;
  }
  .side-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 22px;
  }
  .side-card-accent {
    background: linear-gradient(160deg, var(--navy), var(--navy-deep));
    border-color: transparent;
  }
  .side-card-accent .resume-block-title {
    color: var(--teal-bright);
  }
  .side-card-accent .award {
    color: var(--cream);
    font-size: 0.95rem;
  }
  .side-card-accent .dots-list li {
    color: rgba(245, 250, 249, 0.82);
  }

  .edu-item {
    padding-bottom: 16px;
    margin-bottom: 16px;
    border-bottom: 1px dashed var(--line);
  }
  .edu-item:last-child {
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: none;
  }
  .edu-item h4 {
    font-size: 1rem;
  }
  .edu-item p {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .edu-period {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--teal-deep);
  }

  .lang-item {
    margin-bottom: 14px;
  }
  .lang-item:last-child {
    margin-bottom: 0;
  }
  .lang-top {
    display: flex;
    justify-content: space-between;
    font-size: 0.92rem;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .lang-level {
    color: var(--muted);
    font-weight: 500;
  }
  .lang-bar {
    height: 7px;
    border-radius: 999px;
    background: rgba(14, 35, 54, 0.08);
    overflow: hidden;
  }
  .lang-bar span {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--teal-deep), var(--teal));
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .dots-list {
    margin: 10px 0 0;
    padding-left: 18px;
    display: grid;
    gap: 6px;
  }
  .dots-list li {
    font-size: 0.9rem;
  }
  /* El logo SSI va inline tras el texto para que el <li> conserve su viñeta
     (un display:flex en el li elimina el marker de la lista). */
  .license-ssi :global(.ssi-logo) {
    margin-left: 4px;
  }

  @media (max-width: 860px) {
    .resume-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
