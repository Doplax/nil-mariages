---
import { profile } from '../data/cv';

interface Props {
  tooltip?: string;
}
const { tooltip = 'Escríbeme por WhatsApp' } = Astro.props;
---

<a
  href={profile.whatsapp}
  class="floating-wa"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={tooltip}
  title={tooltip}
  id="floating-wa"
>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z" />
  </svg>
  <span class="floating-wa-tip">{tooltip}</span>
</a>

<script>
  // Re-inicializa en cada `astro:page-load` para seguir funcionando tras
  // una View Transition (cambio de idioma), no solo al recargar la página.
  let waObserver: IntersectionObserver | null = null;

  function initFloatingWa() {
    const btn = document.getElementById('floating-wa');
    const hero = document.getElementById('inicio');
    if (!(btn && hero)) return;
    waObserver?.disconnect();
    waObserver = new IntersectionObserver(
      ([e]) => btn.classList.toggle('is-hidden', e.isIntersecting),
      { threshold: 0.1 },
    );
    waObserver.observe(hero);
  }

  document.addEventListener('astro:page-load', initFloatingWa);
</script>

<style>
  .floating-wa {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 200;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 28px -8px rgba(37, 211, 102, 0.65), 0 2px 8px rgba(0,0,0,0.18);
    transition: transform 0.22s ease, opacity 0.22s ease, box-shadow 0.22s ease;
    text-decoration: none;
  }
  .floating-wa:hover {
    transform: scale(1.08);
    box-shadow: 0 12px 36px -8px rgba(37, 211, 102, 0.75), 0 2px 10px rgba(0,0,0,0.2);
  }
  .floating-wa.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.85);
  }
  .floating-wa-tip {
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    background: var(--navy);
    color: var(--cream);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .floating-wa-tip::after {
    content: '';
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: var(--navy);
  }
  .floating-wa:hover .floating-wa-tip,
  .floating-wa:focus .floating-wa-tip {
    opacity: 1;
  }

  /* Pulse ring */
  .floating-wa::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(37, 211, 102, 0.55);
    animation: wa-pulse 2.4s ease-out infinite;
  }
  @keyframes wa-pulse {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-wa::before { animation: none; }
  }
  @media (max-width: 520px) {
    .floating-wa { bottom: 20px; right: 16px; width: 52px; height: 52px; }
  }
</style>
