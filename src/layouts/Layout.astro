---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nil Mariages · Haya travel — Agente de viajes a medida',
  description = 'Agente de viajes especializado en el diseño y venta de viajes a medida. Más de 40 países visitados en Asia, América, África y Europa.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e2336" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/nil-mariages.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="container header-inner">
        <a href="#inicio" class="header-logo"><Logo variant="cream" /></a>
        <nav class="header-nav" aria-label="Navegación principal">
          <a href="#sobre-mi">Sobre mí</a>
          <a href="#experiencia">Experiencia</a>
          <a href="#proyectos">Futuros proyectos</a>
          <a href="#contacto" class="header-cta">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer" id="contacto">
      <div class="container footer-inner">
        <div class="footer-brand">
          <Logo variant="cream" />
          <p>Diseño y venta de viajes a medida. Experiencias auténticas, asesoramiento cercano.</p>
        </div>
        <div class="footer-cols">
          <div>
            <h4>Navega</h4>
            <a href="#sobre-mi">Sobre mí</a>
            <a href="#experiencia">Experiencia viajera</a>
            <a href="#proyectos">Futuros proyectos</a>
          </div>
          <div>
            <h4>Contacto</h4>
            <a href="mailto:hola@hayatravel.com">hola@hayatravel.com</a>
            <a href="https://wa.me/" target="_blank" rel="noopener">WhatsApp</a>
            <a href="https://instagram.com/" target="_blank" rel="noopener">Instagram</a>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <span>© {new Date().getFullYear()} Nil Mariages · Haya travel</span>
        <span>Hecho con pasión viajera ✈️</span>
      </div>
    </footer>

    <script>
      // Header con fondo al hacer scroll
      const header = document.getElementById('site-header');
      const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 24);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Animación reveal con IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

    <style>
      .site-header {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 50;
        transition: background 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
      }
      .site-header.is-scrolled {
        background: rgba(9, 22, 34, 0.85);
        backdrop-filter: blur(12px);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 18px;
      }
      .header-nav {
        display: flex;
        align-items: center;
        gap: 28px;
      }
      .header-nav a {
        color: rgba(245, 250, 249, 0.82);
        font-weight: 600;
        font-size: 0.95rem;
        transition: color 0.18s ease;
      }
      .header-nav a:hover {
        color: var(--teal-bright);
      }
      .header-cta {
        padding: 9px 20px;
        border-radius: 999px;
        background: var(--teal);
        color: var(--navy) !important;
      }
      .header-cta:hover {
        background: var(--teal-bright);
      }

      .site-footer {
        background: var(--navy-deep);
        color: rgba(245, 250, 249, 0.7);
        padding-top: 64px;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 40px;
        padding-bottom: 40px;
      }
      .footer-brand p {
        margin-top: 16px;
        max-width: 38ch;
        font-size: 0.96rem;
      }
      .footer-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
      }
      .footer-cols h4 {
        color: var(--cream);
        font-size: 0.95rem;
        margin-bottom: 14px;
      }
      .footer-cols a {
        display: block;
        padding-block: 5px;
        font-size: 0.95rem;
        transition: color 0.18s ease;
      }
      .footer-cols a:hover {
        color: var(--teal-bright);
      }
      .footer-bottom {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding-block: 26px;
        margin-top: 8px;
        border-top: 1px solid rgba(245, 250, 249, 0.1);
        font-size: 0.85rem;
      }

      @media (max-width: 720px) {
        .header-nav {
          gap: 16px;
        }
        .header-nav a:not(.header-cta) {
          display: none;
        }
        .footer-inner {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
