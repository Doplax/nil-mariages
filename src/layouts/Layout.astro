---
import '@fontsource-variable/inter';
import 'flag-icons/css/flag-icons.min.css';
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import { profile } from '../data/cv';
import { getDict, localeUrl, LANGS, type Lang } from '../i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const meta: Record<Lang, { title: string; description: string; ogLocale: string }> = {
  es: {
    title: 'Nil Mariages — Agente de viajes a medida',
    description:
      'Agente de viajes especializado en el diseño y venta de viajes a medida. Más de 40 países visitados en Asia, América, África y Europa.',
    ogLocale: 'es_ES',
  },
  en: {
    title: 'Nil Mariages — Tailor-made travel agent',
    description:
      'Travel agent specialised in designing and selling tailor-made trips. 40+ countries visited across Asia, the Americas, Africa and Europe.',
    ogLocale: 'en_GB',
  },
  ca: {
    title: 'Nil Mariages — Agent de viatges a mida',
    description:
      'Agent de viatges especialitzat en el disseny i la venda de viatges a mida. Més de 40 països visitats a Àsia, Amèrica, Àfrica i Europa.',
    ogLocale: 'ca_ES',
  },
};

const { lang, title = meta[lang].title, description = meta[lang].description } = Astro.props;
const d = getDict(lang);
const nav = d.ui.nav;
const foot = d.ui.footer;
const home = localeUrl(lang);
const site = Astro.site ?? new URL('https://nil-mariages.vercel.app');
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e2336" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/nil-mariages.webp" />
    <meta property="og:locale" content={meta[lang].ogLocale} />

    <!-- hreflang -->
    {LANGS.map((l) => <link rel="alternate" hreflang={l} href={new URL(localeUrl(l), site).href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/', site).href} />

    <title>{title}</title>

    <!-- View Transitions (smooth page navigation) -->
    <ClientRouter />

    <!-- Plausible Analytics: activa añadiendo PUBLIC_PLAUSIBLE_DOMAIN en Vercel env vars -->
    {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
      <script
        is:inline
        defer
        data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      />
    )}

    <!-- JSON-LD structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': ['Person', 'LocalBusiness'],
      name: 'Nil Mariages',
      jobTitle: lang === 'en' ? 'Travel Agent' : lang === 'ca' ? 'Agent de viatges' : 'Agente de viajes',
      description: description,
      email: profile.email,
      telephone: profile.phone,
      url: new URL(localeUrl(lang), site).href,
      address: { '@type': 'PostalAddress', addressLocality: 'Barcelona', addressCountry: 'ES' },
      sameAs: [profile.whatsapp, profile.linkedin],
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <header class="site-header" id="site-header">
      <div class="container header-inner">
        <a href={home} class="header-logo" aria-label="Nil Mariages"><Logo variant="cream" /></a>

        <button class="nav-toggle" id="nav-toggle" aria-label="Menú" aria-expanded="false" aria-controls="site-nav">
          <span></span><span></span><span></span>
        </button>

        <nav class="header-nav" id="site-nav" aria-label="Nav">
          <a href="#sobre-mi">{nav.about}</a>
          <a href="#trayectoria">{nav.trayectoria}</a>
          <a href="#experiencia">{nav.viajes}</a>
          <a href="#rutas">{nav.rutas}</a>
          <LangSwitcher current={lang} class="nav-lang" />
          <a href="#contacto" class="header-cta">{nav.contacto}</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <FloatingWhatsApp tooltip={d.ui.cta.whatsapp} />

    <button class="scroll-top" id="scroll-top" aria-label="Volver arriba" title="Volver arriba" hidden>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
    </button>

    <footer class="site-footer" id="contacto">
      <div class="container footer-inner">
        <div class="footer-brand">
          <Logo variant="cream" />
          <p>{foot.tagline}</p>
        </div>
        <div class="footer-cols">
          <div>
            <h4>{foot.navTitle}</h4>
            <a href="#sobre-mi">{nav.about}</a>
            <a href="#trayectoria">{nav.trayectoria}</a>
            <a href="#experiencia">{nav.viajes}</a>
            <a href="#rutas">{nav.rutas}</a>
          </div>
          <div class="footer-contact">
            <h4>{foot.contactTitle}</h4>
            <a href={`mailto:${profile.email}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {profile.email}
            </a>
            <a href={profile.phoneHref}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.15 6.15l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {profile.phone}
            </a>
            <a href={profile.whatsapp} target="_blank" rel="noopener">
              <svg class="ic-wa" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
              WhatsApp
            </a>
            <a href={profile.linkedin} target="_blank" rel="noopener">
              <svg class="ic-li" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/></svg>
              LinkedIn
            </a>
            <a href="#trayectoria">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              {profile.location}
            </a>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <span>© {year} Nil Mariages · {d.ui.about.role}</span>
        <span>{foot.madeWith}</span>
      </div>
    </footer>

    <script>
      // Con View Transitions (<ClientRouter />), los scripts de módulo se
      // ejecutan una sola vez: no vuelven a correr tras navegar (p. ej. al
      // cambiar de idioma). Por eso la configuración que depende del DOM se
      // re-ejecuta en cada `astro:page-load` (carga inicial + cada navegación),
      // mientras que los listeners de `window` se registran una única vez y
      // consultan el DOM en vivo.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // --- Listeners de window: se registran una sola vez ---
      const onScroll = () => {
        const header = document.getElementById('site-header');
        const scrollTopBtn = document.getElementById('scroll-top') as HTMLButtonElement | null;
        header?.classList.toggle('is-scrolled', window.scrollY > 24);
        if (scrollTopBtn) scrollTopBtn.hidden = window.scrollY < 400;
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      let parallaxTicking = false;
      const applyParallax = () => {
        const els = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
        const vh = window.innerHeight;
        for (const el of els) {
          const speed = parseFloat(el.dataset.parallax || '0');
          const rect = el.getBoundingClientRect();
          const offset = rect.top + rect.height / 2 - vh / 2;
          el.style.transform = `translate3d(0, ${(-offset * speed).toFixed(1)}px, 0)`;
        }
        parallaxTicking = false;
      };
      const onParallax = () => {
        if (reduceMotion || parallaxTicking) return;
        window.requestAnimationFrame(applyParallax);
        parallaxTicking = true;
      };
      window.addEventListener('scroll', onParallax, { passive: true });
      window.addEventListener('resize', onParallax, { passive: true });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 860) {
          document.getElementById('site-header')?.classList.remove('is-open');
          document.getElementById('nav-toggle')?.setAttribute('aria-expanded', 'false');
        }
      });

      // --- Configuración por página: carga inicial + cada View Transition ---
      function setupPage() {
        const header = document.getElementById('site-header');

        // Botón "volver arriba"
        document
          .getElementById('scroll-top')
          ?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // Menú móvil (hamburguesa) con trampa de foco
        const toggle = document.getElementById('nav-toggle');
        const nav = document.getElementById('site-nav');
        const closeMenu = () => {
          header?.classList.remove('is-open');
          toggle?.setAttribute('aria-expanded', 'false');
        };
        toggle?.addEventListener('click', () => {
          const open = header?.classList.toggle('is-open') ?? false;
          toggle.setAttribute('aria-expanded', String(open));
          if (open && nav) {
            const first = nav.querySelector<HTMLElement>('a, button');
            setTimeout(() => first?.focus(), 50);
          }
        });
        nav?.addEventListener('keydown', (e) => {
          if (!header?.classList.contains('is-open')) return;
          if (e.key === 'Escape') { closeMenu(); toggle?.focus(); return; }
          if (e.key !== 'Tab') return;
          const focusable = Array.from(nav.querySelectorAll<HTMLElement>('a, button'));
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault(); last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault(); first.focus();
          }
        });
        nav?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

        // Resaltado de la sección activa en el nav
        const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('#site-nav a[href^="#"]'));
        const sections = navLinks
          .map((a) => document.querySelector<HTMLElement>(a.getAttribute('href')!))
          .filter(Boolean) as HTMLElement[];
        const setActive = (id: string) => {
          navLinks.forEach((a) => a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`));
        };
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) setActive(entry.target.id);
            }
          },
          { rootMargin: '-30% 0px -60% 0px' },
        );
        sections.forEach((s) => sectionObserver.observe(s));

        // Animación reveal con IntersectionObserver
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

        // Estado inicial del header y del parallax para la página recién cargada
        onScroll();
        applyParallax();
      }

      document.addEventListener('astro:page-load', setupPage);
    </script>

    <style>
      .scroll-top {
        position: fixed;
        bottom: 100px;
        right: 28px;
        z-index: 190;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--navy);
        color: var(--cream);
        border: 1.5px solid rgba(245, 250, 249, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 4px 16px -6px rgba(14, 35, 54, 0.5);
        transition: transform 0.2s ease, background 0.2s ease, opacity 0.25s ease;
        opacity: 1;
      }
      .scroll-top[hidden] {
        display: flex !important;
        opacity: 0;
        pointer-events: none;
        transform: translateY(10px);
      }
      .scroll-top:hover {
        background: var(--navy-soft);
        transform: translateY(-2px);
      }
      @media (max-width: 520px) {
        .scroll-top { right: 16px; bottom: 88px; width: 38px; height: 38px; }
      }
      .skip-link {
        position: absolute;
        top: -100%;
        left: 16px;
        padding: 10px 18px;
        background: var(--teal);
        color: var(--navy);
        font-weight: 700;
        border-radius: 0 0 var(--radius) var(--radius);
        z-index: 9999;
        transition: top 0.15s ease;
      }
      .skip-link:focus {
        top: 0;
      }
      .site-header {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 50;
        transition: background 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
      }
      .site-header.is-scrolled,
      .site-header.is-open {
        background: rgba(9, 22, 34, 0.92);
        backdrop-filter: blur(12px);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 16px;
        position: relative;
      }
      .header-nav {
        display: flex;
        align-items: center;
        gap: 26px;
      }
      .header-nav a:not(.header-cta) {
        position: relative;
        color: rgba(245, 250, 249, 0.82);
        font-weight: 600;
        font-size: 0.95rem;
        transition: color 0.18s ease;
      }
      .header-nav a:not(.header-cta)::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -6px;
        height: 2px;
        background: var(--teal-bright);
        border-radius: 2px;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.25s ease;
      }
      .header-nav a:not(.header-cta):hover {
        color: var(--teal-bright);
      }
      .header-nav a:not(.header-cta):hover::after,
      .header-nav a:not(.header-cta).is-active::after {
        transform: scaleX(1);
      }
      .header-nav a:not(.header-cta).is-active {
        color: var(--teal-bright);
      }
      .header-cta {
        padding: 9px 20px;
        border-radius: 999px;
        background: var(--teal);
        color: var(--navy) !important;
        transition: background 0.18s ease, transform 0.18s ease;
      }
      .header-cta:hover {
        background: var(--teal-bright);
        transform: translateY(-1px);
      }

      /* Botón hamburguesa (oculto en escritorio) */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 42px;
        height: 42px;
        padding: 0;
        border: 1px solid rgba(245, 250, 249, 0.2);
        border-radius: 12px;
        background: rgba(245, 250, 249, 0.04);
        cursor: pointer;
      }
      .nav-toggle span {
        display: block;
        width: 20px;
        height: 2px;
        margin-inline: auto;
        background: var(--cream);
        border-radius: 2px;
        transition: transform 0.25s ease, opacity 0.2s ease;
      }
      .site-header.is-open .nav-toggle span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .site-header.is-open .nav-toggle span:nth-child(2) {
        opacity: 0;
      }
      .site-header.is-open .nav-toggle span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      .site-footer {
        background: var(--navy-deep);
        color: rgba(245, 250, 249, 0.7);
        padding-top: 64px;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 40px;
        padding-bottom: 40px;
      }
      .footer-brand p {
        margin-top: 16px;
        max-width: 38ch;
        font-size: 0.96rem;
      }
      .footer-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
      }
      .footer-cols h4 {
        color: var(--cream);
        font-size: 0.95rem;
        margin-bottom: 14px;
      }
      .footer-cols a {
        display: block;
        padding-block: 5px;
        font-size: 0.95rem;
        transition: color 0.18s ease;
      }
      .footer-cols a:hover {
        color: var(--teal-bright);
      }
      .footer-cols .footer-contact a {
        display: inline-flex;
        align-items: center;
        gap: 9px;
      }
      .footer-contact a svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        color: var(--teal-bright);
      }
      .footer-contact a svg.ic-wa {
        color: #25d366;
      }
      .footer-contact a svg.ic-li {
        color: #4aa3df;
      }
      .footer-bottom {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding-block: 26px;
        margin-top: 8px;
        border-top: 1px solid rgba(245, 250, 249, 0.1);
        font-size: 0.85rem;
      }

      /* ---- Responsive: menú móvil desplegable ---- */
      @media (max-width: 860px) {
        .nav-toggle {
          display: flex;
        }
        .header-nav {
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 4px;
          padding: 14px 24px 22px;
          background: rgba(9, 22, 34, 0.98);
          backdrop-filter: blur(14px);
          border-top: 1px solid rgba(245, 250, 249, 0.08);
          box-shadow: 0 24px 40px -20px rgba(0, 0, 0, 0.6);
          opacity: 0;
          transform: translateY(-10px);
          pointer-events: none;
          transition: opacity 0.22s ease, transform 0.22s ease;
        }
        .site-header.is-open .header-nav {
          opacity: 1;
          transform: none;
          pointer-events: auto;
        }
        .header-nav a:not(.header-cta) {
          padding: 12px 4px;
          font-size: 1.05rem;
          border-bottom: 1px solid rgba(245, 250, 249, 0.06);
        }
        .header-nav a:not(.header-cta)::after {
          display: none;
        }
        .nav-lang {
          margin-top: 14px;
          align-self: flex-start;
        }
        .header-cta {
          margin-top: 14px;
          text-align: center;
          padding: 13px 20px;
        }
        .footer-inner {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
